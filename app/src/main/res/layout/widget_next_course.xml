<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_next_course_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:gravity="center"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/widget_next_course_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="下一节课"
        android:textColor="#B3FFFFFF"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_next_course_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="课程名"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_next_course_classroom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="教室"
        android:textColor="#B3FFFFFF"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_next_course_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="还有 25 分钟"
        android:textColor="#FF03DAC5"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_next_course_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="今日暂无课程"
        android:textColor="#80FFFFFF"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
